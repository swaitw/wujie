{
  "packages": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "npmClient": "pnpm",
  "command": {
    "version": {
      "allowBranch": "master",
      "conventionalCommits": true,
      "syncWorkspaceLock": true,
      "commitHooks": false
    },
    "bootstrap": {
      "npmClientArgs": [
        "--no-package-lock",
        "--legacy-peer-deps"
      ]
    }
  },
  "version": "2.1.0"
}
