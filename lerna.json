{
  "packages": ["packages/*", "examples/*", "docs"],
  "npmClient": "pnpm",
  "command": {
    "version": {
      "allowBranch": "master",
      "conventionalCommits": true,
      "syncWorkspaceLock": true
    },
    "bootstrap": {
      "npmClientArgs": ["--no-package-lock", "--legacy-peer-deps"]
    }
  },
  "version": "2.0.2"
}
