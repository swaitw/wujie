else
  export NODE_PATH="/Users/xuzhidan/work/wujie/.worktree/fix-nested-font-style/node_modules/.pnpm/@babel+cli@7.28.3_@babel+core@7.28.4/node_modules/@babel/cli/node_modules:/Users/xuzhidan/work/wujie/.worktree/fix-nested-font-style/node_modules/.pnpm/@babel+cli@7.28.3_@babel+core@7.28.4/node_modules:/Users/xuzhidan/work/wujie/.worktree/fix-nested-font-style/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@babel/cli/bin/babel-external-helpers.js" "$@"
else
  exec node  "$basedir/../@babel/cli/bin/babel-external-helpers.js" "$@"
fi
